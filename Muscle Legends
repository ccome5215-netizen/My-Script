                        newGlue.Part0 = rightHand
                        newGlue.Part1 = handle
                        newGlue.Parent = handle
                    end)
                end
            end
        else
            -- If not holding weight or not finding it in char, clean up glue if it somehow got stuck on a handle in backpack
            local bp = player:FindFirstChild("Backpack")
            if bp then
                for _, t in ipairs(bp:GetChildren()) do
                    if t:IsA("Tool") and t.Name == "Weight" then
                        local h = t:FindFirstChild("Handle")
                        if h then
                            local g = h:FindFirstChild("WeightGlue")
                            if g then g:Destroy() end
                        end
                    end
                end
            end
        end
    end
end))

