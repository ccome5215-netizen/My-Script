-- Auto Glitch loop (unchanged)
table.insert(getgenv().ML_Expert_Loops, task.spawn(function()
    while true do
        task.wait()
        if not states.autoGlitch then continue end
        local char = player.Character
        if not char or not states.selectedRock or not states.selectedMethod then continue end
        local root, hum = char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
        if not root or not hum or hum.Health <= 0 then continue end
        if states.isTransitioning then continue end

        local rockModel = getRockInstance(states.selectedRock)
        if not rockModel then continue end
        local actualRockPart = rockModel:FindFirstChild("Rock") or rockModel:FindFirstChildWhichIsA("BasePart")
        if not actualRockPart then continue end

        local punchTool = getPunch()
        if punchTool and punchTool.Parent ~= char then 
            pcall(function() punchTool.Parent = char end)
        end

        if states.selectedMethod == "Teleport" then 
            if punchTool and punchTool:FindFirstChild("attackTime") then punchTool.attackTime.Value = 0.05 end
            local edgeOffset = (actualRockPart.Size.Z / 2) + 2.5 + ((tonumber(Config.SizeValue) or 1) * 0.25)
            root.CFrame = CFrame.lookAt((actualRockPart.CFrame * CFrame.new(0, 0, edgeOffset)).Position, actualRockPart.Position)
            if punchTool then punchTool:Activate() end

        elseif states.selectedMethod == "NonTeleport" then 
            local currentHand = toggleHand and "Left" or "Right"
            local targetHand = char:FindFirstChild(currentHand .. "Hand") or char:FindFirstChild(currentHand .. " Arm")
            toggleHand = not toggleHand
            if targetHand then 
                if not rockCache[actualRockPart] then 
                    rockCache[actualRockPart] = {
                        Size = actualRockPart.Size, 
                        CanCollide = actualRockPart.CanCollide, 
                        CFrame = actualRockPart.CFrame,
                        Anchored = actualRockPart.Anchored
                    } 
                end
                actualRockPart.CanCollide = false
                actualRockPart.Anchored = false
                local mySize = player:FindFirstChild("customSize") and player.customSize.Value or tonumber(Config.SizeValue) or 1
                local newSize = math.min(2, math.max(0.5, mySize / 2))
                actualRockPart.Size = Vector3.new(newSize, newSize, newSize)
                actualRockPart.CFrame = targetHand.CFrame
                actualRockPart.AssemblyLinearVelocity = Vector3.zero
                actualRockPart.AssemblyAngularVelocity = Vector3.zero
            end
            pcall(function()
                local args1 = { [1] = "punch", [2] = "leftHand" }
                player.muscleEvent:FireServer(unpack(args1))
                local args2 = { [1] = "punch", [2] = "rightHand" }
                player.muscleEvent:FireServer(unpack(args2))
            end)
            task.wait(0.05)
        end

        if not states.autoGlitchTrain then 
            for _, tool in ipairs(char:GetChildren()) do 
                if tool:IsA("Tool") and tool.Name ~= "Punch" then 
                    local bp = player:FindFirstChild("Backpack")
                    if bp then
                        pcall(function() tool.Parent = bp end)
                    end
                end 
            end
        end
    end
end))

