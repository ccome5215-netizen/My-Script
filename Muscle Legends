-- Check if local player is current Muscle King
local function isLocalPlayerMuscleKing()
    local mkPart = workspace:FindFirstChild("currentMuscleKingPart")
    if not mkPart then return false end
    local mkGui = mkPart:FindFirstChild("currentMuscleKingGui")
    if not mkGui then return false end
    local mkLabel = mkGui:FindFirstChild("currentMuscleKingLabel")
    if not mkLabel or not mkLabel:IsA("TextLabel") then return false end
    return mkLabel.Text == "Muscle King: " .. player.Name
end

-- Get strength
local function getStrength()
    return player.leaderstats and player.leaderstats:FindFirstChild("Strength") and player.leaderstats.Strength.Value or 0
end

-- Stop auto gym
local function stopAutoGym()
    if states.autoGymThread then
        pcall(task.cancel, states.autoGymThread)
        states.autoGymThread = nil
    end
    states.autoGym = false
end

-- Start auto gym
local function startAutoGym()
    stopAutoGym()
    if not states.selectedMap or not states.selectedGym then return end
    states.autoGym = true
    states.autoGymThread = task.spawn(function()
        while states.autoGym and states.selectedMap and states.selectedGym do
            local map = gymData[states.selectedMap]
            if not map then break end
            local gym = map[states.selectedGym]
            if not gym then break end

            -- Strength check
            local cost = gym.cost
            if cost then
                if getStrength() < cost then
                    if states.lessLag then task.wait(0.5) else task.wait(0.1) end
                    continue
                end
            end

            -- Muscle King check
            if states.selectedMap == "Muscle King Island" and not isLocalPlayerMuscleKing() then
                if states.lessLag then task.wait(0.5) else task.wait(0.1) end
                continue
            end

            local chr = player.Character
            if not chr or not chr:FindFirstChild("HumanoidRootPart") then
                task.wait(0.2)
                continue
            end
            local root = chr.HumanoidRootPart
            local hum = chr:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then
                task.wait(0.2)
                continue
            end
            
            -- Ignore/Do nothing if character is already sitting
            if hum.Sit then
                task.wait(0.5)
                continue
            end

            -- Teleport to gym
            root.CFrame = CFrame.new(gym.pos)
            root.AssemblyLinearVelocity = Vector3.zero
            fireEKey()

            -- Wait until sitting
            local sitWait = 0
            while states.autoGym and states.selectedGym == gym and sitWait < 5 do
                if chr:FindFirstChild("Seat") or (hum and hum.Sit) then break end
                task.wait(0.2)
                sitWait = sitWait + 0.2
            end

            task.wait(0.5)
        end
        states.autoGym = false
    end)
end

-- Toggle auto gym (from button)
local function toggleAutoGym()
    if states.autoGym then
        stopAutoGym()
    else
        startAutoGym()
    end
end

