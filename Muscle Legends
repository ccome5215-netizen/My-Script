-- Improved interact seat finder (searches all machines, finds any interactSeat inside)
local function findAnyInteractSeat(nearPos)
    local folder = workspace:FindFirstChild("machinesFolder")
    if not folder then return nil end
    local bestSeat = nil
    local bestDist = 50
    for _, machine in ipairs(folder:GetChildren()) do
        local seat = machine:FindFirstChild("interactSeat")
        if seat then
            local machinePos = machine:FindFirstChild("PrimaryPart") or machine:FindFirstChildWhichIsA("BasePart")
            if machinePos then
                local dist = (machinePos.Position - nearPos).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestSeat = seat
                end
            end
        end
    end
    return bestSeat
end

-- Find seat by name, fallback to any seat if not found
local function findInteractSeatByName(gymName, nearPos)
    local folder = workspace:FindFirstChild("machinesFolder")
    if not folder then return findAnyInteractSeat(nearPos) end
    -- First try exact name match
    for _, machine in ipairs(folder:GetChildren()) do
        if machine.Name == gymName then
            local seat = machine:FindFirstChild("interactSeat")
            if seat then
                return seat
            end
        end
    end
    -- Fallback: search all machines for any seat
    return findAnyInteractSeat(nearPos)
end

-- Fire machine interact remote
local function fireMachineInteract(seat)
    pcall(function()
        local args = {
            [1] = "useMachine",
            [2] = seat,
        }
        ReplicatedStorage.rEvents.machineInteractRemote:InvokeServer(unpack(args))
    end)
end

-- Stop auto gym
local function stopAutoGym()
    if states.autoGymThread then
        pcall(task.cancel, states.autoGymThread)
        states.autoGymThread = nil
    end
    states.autoGym = false
end

-- Start auto gym (repeatedly teleports and attempts to sit until seated)
local function startAutoGym()
    stopAutoGym()
    if not states.selectedMap or not states.selectedGym then return end
    states.autoGym = true
    states.autoGymThread = task.spawn(function()
        while states.autoGym and states.selectedMap and states.selectedGym do
            local map = gymData[states.selectedMap]
            if not map then break end
            local gym = map[states.selectedGym]
            if not gym then break end

            -- Strength check
            local cost = gym.cost
            if cost and getStrength() < cost then
                if states.lessLag then task.wait(0.5) else task.wait(0.1) end
                continue
            end

            -- Muscle King check
            if states.selectedMap == "Muscle King Island" and not isLocalPlayerMuscleKing() then
                if states.lessLag then task.wait(0.5) else task.wait(0.1) end
                continue
            end

            local chr = player.Character
            if not chr or not chr:FindFirstChild("HumanoidRootPart") then
                task.wait(0.2)
                continue
            end
            local root = chr.HumanoidRootPart
            local hum = chr:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then
                task.wait(0.2)
                continue
            end
            
            -- If already sitting, we are done for this cycle
            if hum.Sit then
                task.wait(0.5)
                continue
            end

            -- Teleport to gym position
            root.CFrame = CFrame.new(gym.pos)
            root.AssemblyLinearVelocity = Vector3.zero
            task.wait(0.1)

            -- Find seat
            local seat = findInteractSeatByName(states.selectedGym, gym.pos)
            if seat then
                fireMachineInteract(seat)
            else
                fireEKey()
            end

            -- Wait to sit, but keep trying if not sitting within 1 second
            local startWait = tick()
            while states.autoGym and states.selectedGym == gym and tick() - startWait < 5 do
                if hum.Sit then break end
                task.wait(0.2)
                -- If still not sitting, re-teleport and try again
                if not hum.Sit and tick() - startWait > 1 then
                    root.CFrame = CFrame.new(gym.pos)
                    root.AssemblyLinearVelocity = Vector3.zero
                    if seat then
                        fireMachineInteract(seat)
                    else
                        fireEKey()
                    end
                    startWait = tick()
                end
            end

            task.wait(0.5)
        end
        states.autoGym = false
    end)
end

-- Toggle auto gym
local function toggleAutoGym()
    if states.autoGym then
        stopAutoGym()
    else
        startAutoGym()
    end
end

