local function getTeleportPosForMap(currentMap)
    if not currentMap or currentMap == "" then return Vector3.new(4.466469, 7.303733, 132.878891) end
    local lowerMap = currentMap:lower()
    if lowerMap:find("jungle") then
        return Vector3.new(-8685.621094, 6.732735, 2392.326660)
    elseif lowerMap:find("muscle king") then
        return Vector3.new(-8625.929688, 17.153761, -5730.473145)
    elseif lowerMap:find("beach") then
        return Vector3.new(4.466469, 7.303733, 132.878891)
    elseif lowerMap:find("tiny") then
        return Vector3.new(-33.693745, 7.456870, 1892.807007)
    elseif lowerMap:find("frozen") then
        return Vector3.new(-2623.022217, 7.303728, -409.073334)
    elseif lowerMap:find("mystic") then
        return Vector3.new(2250.778076, 7.303732, 1073.226685)
    elseif lowerMap:find("inferno") then
        return Vector3.new(-6758.963867, 7.303741, -1284.918701)
    elseif lowerMap:find("legend") then
        return Vector3.new(4603.281738, 991.481750, -3897.865723)
    else
        return Vector3.new(4.466469, 7.303733, 132.878891)
    end
end

