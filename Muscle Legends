table.insert(getgenv().ML_Expert_Loops, task.spawn(function()
    while true do
        if states.lessLag then task.wait(0.1) else RunService.Heartbeat:Wait() end
        local char = player.Character
        if not char then continue end
        
        local p = getPunch()
        if p and p:FindFirstChild("attackTime") then
            local anyKillActive = states.killActive or states.killEveryone or states.autoGoodKarma or states.autoEvilKarma
            if states.fastPunch or anyKillActive then
                pcall(function() p.attackTime.Value = 0 end)
            elseif not states.autoGlitch then
                pcall(function() p.attackTime.Value = 0.35 end)
            end
        end
        
        if states.autoPunch and not states.isTransitioning then
            local equippedTool = char:FindFirstChildOfClass("Tool")
            if equippedTool and equippedTool.Name == "Punch" then
                pcall(function() equippedTool:Activate() end)
            end
        end
        
        if states.accelReps then
            local ult = player:FindFirstChild("ultimatesFolder") and player.ultimatesFolder:FindFirstChild("+5% Rep Speed")
            if ult and ult.Value ~= 1000 then pcall(function() ult.Value = 1000 end) end
        end
    end
end))
