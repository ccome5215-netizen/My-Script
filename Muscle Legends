local function stopAutoGym()
    if states.autoGymThread then
        pcall(task.cancel, states.autoGymThread)
        states.autoGymThread = nil
    end
    states.autoGym = false
end

local function startAutoGym()
    stopAutoGym()
    if not states.selectedMap or not states.selectedGym then return end
    states.autoGym = true

    local lastTpTime   = 0
    local lastFireTime = 0
    local TP_CD        = 0.5
    local FIRE_CD      = 0.15

    states.autoGymThread = task.spawn(function()
        while states.autoGym and states.selectedMap and states.selectedGym do
            task.wait()
            if states.stopEverything then continue end

            local mapData = gymData[states.selectedMap]
            if not mapData then continue end
            local gym = mapData[states.selectedGym]
            if not gym then continue end

            if gym.cost and getStrength() < gym.cost then continue end
            if states.selectedMap == "Muscle King Island" then
                if not isLocalPlayerMuscleKing() and not isMuscleKingNone() then continue end
            end

            local char = player.Character
            if not char then continue end
            local root = char:FindFirstChild("HumanoidRootPart")
            local hum  = char:FindFirstChild("Humanoid")
            if not root or not hum or hum.Health <= 0 then continue end

            if hum.Sit then continue end

            local now = tick()

            if now - lastTpTime >= TP_CD then
                pcall(function()
                    root.CFrame = CFrame.new(gym.pos + Vector3.new(0, 4, 0))
                    root.AssemblyLinearVelocity = Vector3.zero
                end)
                lastTpTime = now
            end

            if now - lastFireTime >= FIRE_CD then
                local seat = findBestSeat(gym.pos)
                if seat then
                    fireMachineInteract(seat)
                end
                fireEKey()
                lastFireTime = now
            end
        end
        states.autoGym = false
    end)
end

