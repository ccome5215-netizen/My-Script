-- ==================== AUTO GYM SECTION ====================
local function findBestSeat(nearPos)
    local folder = workspace:FindFirstChild("machinesFolder")
    if not folder then return nil end
    local bestPart = nil
    local bestDist = math.huge

    for _, obj in ipairs(folder:GetDescendants()) do
        if obj:IsA("Seat") or obj:IsA("VehicleSeat") then
            local dist = (obj.Position - nearPos).Magnitude
            if dist < bestDist and dist < 50 then
                bestDist = dist
                bestPart = obj
            end
        end
    end

    if bestDist > 15 then
        for _, obj in ipairs(folder:GetDescendants()) do
            if obj:IsA("BasePart") then
                local n = obj.Name:lower()
                if n:find("interact") or n:find("trigger") or n:find("prompt") or n == "root" then
                    local dist = (obj.Position - nearPos).Magnitude
                    if dist < bestDist and dist < 30 then
                        bestDist = dist
                        bestPart = obj
                    end
                end
            end
        end
    end

    if bestDist > 15 then
        for _, model in ipairs(folder:GetChildren()) do
            if model:IsA("Model") then
                local ref = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
                if ref then
                    local dist = (ref.Position - nearPos).Magnitude
                    if dist < bestDist and dist < 30 then
                        bestDist = dist
                        bestPart = ref
                    end
                end
            end
        end
    end

    if not bestPart then
        for _, obj in ipairs(folder:GetDescendants()) do
            if obj:IsA("BasePart") then
                local dist = (obj.Position - nearPos).Magnitude
                if dist < bestDist and dist < 20 then
                    bestDist = dist
                    bestPart = obj
                end
            end
        end
    end

    return bestPart
end

