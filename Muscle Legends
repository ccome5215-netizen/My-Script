-- Storage for item tracking (NEW / CHANGED)
local itemMarks = {
    pets = {},   -- key = displayName, value = { type = "NEW" or "CHANGED", timer = nil }
    auras = {}
}
local changedTimers = {}

local function getItemSnapshot(item)
    local snap = {
        name = item.Name,
        xp = item:FindFirstChild("exp") and item.exp.Value or 0,
        level = item:FindFirstChild("level") and item.level.Value or 1,
        strength = 0, durability = 0, agility = 0, damage = 0
    }
    local perks = item:FindFirstChild("perksFolder")
    if perks then
        for _, pName in ipairs({"strength", "durability", "agility", "damage"}) do
            local pObj = perks:FindFirstChild(pName)
            if pObj then
                local val = pObj:IsA("ValueBase") and pObj.Value or (pObj:FindFirstChild("Value") and pObj.Value.Value) or 0
                snap[pName] = val
            end
        end
    end
    return snap
end

local function clearMark(displayName, category)
    if not displayName then return end
    local marks = (category == "pet") and itemMarks.pets or itemMarks.auras
    if marks[displayName] then
        marks[displayName] = nil
    end
    if changedTimers[displayName] then
        changedTimers[displayName]:Disconnect()
        changedTimers[displayName] = nil
    end
end

local function applyMarkToDisplayName(displayName, mark)
    if mark == "NEW" then
        if not displayName:match("%[NEW%]") then
            return displayName .. " [NEW]"
        end
    elseif mark == "CHANGED" then
        if not displayName:match("%[CHANGED%]") then
            -- remove any existing [NEW] or other marks first
            local clean = displayName:gsub("%s*%[[^%]]+%]%s*", "")
            return clean .. " [CHANGED]"
        end
    end
    return displayName
end

local function refreshPetDropdown(category, folderRef, dropdownObj, markCategory)
    if not folderRef then return end
    local counts = {}
    local options = {}
    local itemRefs = {}
    for _, item in ipairs(folderRef:GetChildren()) do
        local baseName = item.Name
        counts[baseName] = (counts[baseName] or 0) + 1
        local displayName = baseName .. " #" .. counts[baseName]
        local mark = itemMarks[markCategory] and itemMarks[markCategory][displayName]
        if mark then
            displayName = applyMarkToDisplayName(displayName, mark)
        end
        table.insert(options, displayName)
        itemRefs[displayName] = item
    end
    if #options == 0 then
        options = {"Nothing Here"}
    end
    dropdownObj.refresh(options)
    -- store refs for later use
    if markCategory == "pets" then
        if folderRef.Name == "Basic" then petRefsBasic = itemRefs
        elseif folderRef.Name == "Advanced" then petRefsAdv = itemRefs
        elseif folderRef.Name == "Rare" then petRefsRare = itemRefs
        elseif folderRef.Name == "Epic" then petRefsEpic = itemRefs
        elseif folderRef.Name == "Unique" then petRefsUnique = itemRefs
        end
    else
        if folderRef.Name == "Basic" then auraRefsBasic = itemRefs
        elseif folderRef.Name == "Advanced" then auraRefsAdv = itemRefs
        elseif folderRef.Name == "Rare" then auraRefsRare = itemRefs
        elseif folderRef.Name == "Epic" then auraRefsEpic = itemRefs
        elseif folderRef.Name == "Unique" then auraRefsUnique = itemRefs
        end
    end
end

local function setupFolderWatcher(folder, dropdownObj, category, subCategory)
    if not folder then return end
    local function update()
        refreshPetDropdown(subCategory, folder, dropdownObj, category)
    end
    folder.ChildAdded:Connect(update)
    folder.ChildRemoved:Connect(update)
    -- also watch for changes inside items? (for CHANGED marking)
    for _, item in ipairs(folder:GetChildren()) do
        if item:IsA("BoolValue") or item:IsA("NumberValue") or item:IsA("IntValue") then
            -- we'll use a single loop for all attribute changes; simpler: periodic check in main loop
        end
    end
end

-- Periodic check for value changes (every 2 seconds)
local function startStatsChangeMonitor()
    task.spawn(function()
        while true do
            task.wait(2)
            if not states.trackStats or not states.statsTarget then continue end
            local tp = Players:FindFirstChild(states.statsTarget)
            if not tp then continue end
            local petsFolder = tp:FindFirstChild("petsFolder")
            if petsFolder then
                for _, rarityFolder in ipairs({"Basic", "Advanced", "Rare", "Epic", "Unique"}) do
                    local f = petsFolder:FindFirstChild(rarityFolder)
                    if f then
                        for _, item in ipairs(f:GetChildren()) do
                            local baseName = item.Name
                            -- we need to find its display name (with #)
                            local count = 0
                            for _, other in ipairs(f:GetChildren()) do
                                if other.Name == baseName then count = count + 1 end
                                if other == item then break end
                            end
                            local displayName = baseName .. " #" .. count
                            local oldSnap = lastItemSnap.pets and lastItemSnap.pets[displayName]
                            local newSnap = getItemSnapshot(item)
                            if oldSnap then
                                local changed = false
                                if oldSnap.xp ~= newSnap.xp or oldSnap.level ~= newSnap.level then changed = true end
                                for _, stat in ipairs({"strength", "durability", "agility", "damage"}) do
                                    if oldSnap[stat] ~= newSnap[stat] then changed = true break end
                                end
                                if changed then
                                    if not itemMarks.pets[displayName] or itemMarks.pets[displayName] ~= "CHANGED" then
                                        itemMarks.pets[displayName] = "CHANGED"
                                        if changedTimers[displayName] then changedTimers[displayName]:Disconnect() end
                                        changedTimers[displayName] = task.delay(2, function()
                                            if itemMarks.pets[displayName] == "CHANGED" then
                                                itemMarks.pets[displayName] = nil
                                                refreshPetDropdown(rarityFolder, f, getDropdownForRarity(rarityFolder, "pet"), "pets")
                                            end
                                            changedTimers[displayName] = nil
                                        end)
                                        refreshPetDropdown(rarityFolder, f, getDropdownForRarity(rarityFolder, "pet"), "pets")
                                    end
                                end
                            end
                            if not lastItemSnap.pets then lastItemSnap.pets = {} end
                            lastItemSnap.pets[displayName] = newSnap
                        end
                    end
                end
            end
            -- similar for auras
            local aurasFolder = tp:FindFirstChild("powerUpsFolder")
            if aurasFolder then
                for _, rarityFolder in ipairs({"Basic", "Advanced", "Rare", "Epic", "Unique"}) do
                    local f = aurasFolder:FindFirstChild(rarityFolder)
                    if f then
                        for _, item in ipairs(f:GetChildren()) do
                            local baseName = item.Name
                            local count = 0
                            for _, other in ipairs(f:GetChildren()) do
                                if other.Name == baseName then count = count + 1 end
                                if other == item then break end
                            end
                            local displayName = baseName .. " #" .. count
                            local oldSnap = lastItemSnap.auras and lastItemSnap.auras[displayName]
                            local newSnap = getItemSnapshot(item)
                            if oldSnap then
                                local changed = false
                                if oldSnap.xp ~= newSnap.xp or oldSnap.level ~= newSnap.level then changed = true end
                                for _, stat in ipairs({"strength", "durability", "agility", "damage"}) do
                                    if oldSnap[stat] ~= newSnap[stat] then changed = true break end
                                end
                                if changed then
                                    if not itemMarks.auras[displayName] or itemMarks.auras[displayName] ~= "CHANGED" then
                                        itemMarks.auras[displayName] = "CHANGED"
                                        if changedTimers[displayName] then changedTimers[displayName]:Disconnect() end
                                        changedTimers[displayName] = task.delay(2, function()
                                            if itemMarks.auras[displayName] == "CHANGED" then
                                                itemMarks.auras[displayName] = nil
                                                refreshPetDropdown(rarityFolder, f, getDropdownForRarity(rarityFolder, "aura"), "auras")
                                            end
                                            changedTimers[displayName] = nil
                                        end)
                                        refreshPetDropdown(rarityFolder, f, getDropdownForRarity(rarityFolder, "aura"), "auras")
                                    end
                                end
                            end
                            if not lastItemSnap.auras then lastItemSnap.auras = {} end
                            lastItemSnap.auras[displayName] = newSnap
                        end
                    end
                end
            end
        end
    end)
end

local function getDropdownForRarity(rarity, type)
    if type == "pet" then
        if rarity == "Basic" then return basicDD
        elseif rarity == "Advanced" then return advDD
        elseif rarity == "Rare" then return rareDD
        elseif rarity == "Epic" then return epicDD
        elseif rarity == "Unique" then return uniqueDD
        end
    else
        if rarity == "Basic" then return auraBasicDD
        elseif rarity == "Advanced" then return auraAdvDD
        elseif rarity == "Rare" then return auraRareDD
        elseif rarity == "Epic" then return auraEpicDD
        elseif rarity == "Unique" then return auraUniqueDD
        end
    end
    return nil
end

local function processSpecificFolderItems(folder)
    if not folder then return {"Nothing Here"}, {} end;
    local counts, itemRefs, found = {}, {}, false; 
    local options = {};
    for _, item in ipairs(folder:GetChildren()) do 
        found = true;
        local baseName = item.Name
        counts[baseName] = (counts[baseName] or 0) + 1;
        local displayName = baseName .. " #" .. counts[baseName]
        -- check for NEW mark (if item was added after last selection)
        if lastItemSnap and lastItemSnap.newItems and lastItemSnap.newItems[displayName] then
            displayName = displayName .. " [NEW]"
            itemMarks.pets[displayName] = "NEW"
        end
        table.insert(options, displayName)
        itemRefs[displayName] = item 
    end;
    if not found then return {"Nothing Here"}, {} end; 
    return options, itemRefs
end

local lastItemSnap = { pets = {}, auras = {}, newItems = {} }

local function handleItemSelection(label, refTable, detailLabel, category)
    if not label or label == "Nothing Here" then return end;
    -- remove marks when selected (except CHANGED will auto-expire)
    if category == "pet" then
        if itemMarks.pets[label] then
            itemMarks.pets[label] = nil
            -- refresh the dropdown to remove mark
            -- find which rarity folder this belongs to
            for rarity, dd in pairs({Basic=basicDD, Advanced=advDD, Rare=rareDD, Epic=epicDD, Unique=uniqueDD}) do
                if dd and dd.optionsList and table.find(dd.optionsList, label) then
                    refreshPetDropdown(rarity, getFolderForRarity(rarity, "pet"), dd, "pets")
                    break
                end
            end
        end
    else
        if itemMarks.auras[label] then
            itemMarks.auras[label] = nil
            for rarity, dd in pairs({Basic=auraBasicDD, Advanced=auraAdvDD, Rare=auraRareDD, Epic=auraEpicDD, Unique=auraUniqueDD}) do
                if dd and dd.optionsList and table.find(dd.optionsList, label) then
                    refreshPetDropdown(rarity, getFolderForRarity(rarity, "aura"), dd, "auras")
                    break
                end
            end
        end
    end
    
    local cleanLabel = label:gsub("%s*%[[^%]]+%]%s*", "")
    local item = refTable[cleanLabel] or refTable[label]
    if item then
        local isEvolved = false
        local evObj = item:FindFirstChild("Evolved") or item:FindFirstChild("evolved")
        if evObj and evObj:IsA("BoolValue") then isEvolved = evObj.Value end

        local txt = "Evolved: " .. tostring(isEvolved) .. "\nXP: " .. formatNum(item:FindFirstChild("exp") and item.exp.Value or 0) .. "\nLevel: " .. formatNum(item:FindFirstChild("level") and item.level.Value or 1) .. "\nRequires Rebirth: " .. formatNum(item:FindFirstChild("requiredRebirths") and item.requiredRebirths.Value or 0) .. "\n\nPerks:\n";
        local perks = item:FindFirstChild("perksFolder")
        for _, pName in ipairs({"strength", "durability", "agility", "damage"}) do local fv = "Not Found";
        if perks then local pObj = perks:FindFirstChild(pName); if pObj then fv = formatNum(pObj:IsA("ValueBase") and pObj.Value or (pObj:FindFirstChild("Value") and pObj.Value.Value)) end end;
        txt = txt .. pName:sub(1,1):upper() .. pName:sub(2) .. ": " .. fv .. "\n" end;
        detailLabel.Text = txt
    end
end

local function processAuraItems(folder)
    if not folder then return {"Nothing Here"}, {} end;
    local counts, itemRefs, found = {}, {}, false; local options = {};
    for _, item in ipairs(folder:GetChildren()) do found = true; local baseName = item.Name; counts[baseName] = (counts[baseName] or 0) + 1;
    local displayName = baseName .. " #" .. counts[baseName];
    if lastItemSnap and lastItemSnap.newItems and lastItemSnap.newItems[displayName] then
        displayName = displayName .. " [NEW]"
        itemMarks.auras[displayName] = "NEW"
    end
    table.insert(options, displayName); itemRefs[displayName] = item end;
    if not found then return {"Nothing Here"}, {} end; return options, itemRefs
end

