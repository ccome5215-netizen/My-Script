                                statGainTimes[s] = nil
                            end
                        end
                        
                        label.Text = s .. ": " .. formatNum(current) .. (s == "Rebirth Multiplier" and "%" or "") .. gainStr 
                    else 
                        label.Text = s .. ": " .. tostring(rawVal) 
                    end
                end
                
                if states.currentPetLabel then
                    local petList = petRefsBasic
                    if states.currentPetTable == "Basic" then petList = petRefsBasic
                    elseif states.currentPetTable == "Advanced" then petList = petRefsAdv
                    elseif states.currentPetTable == "Rare" then petList = petRefsRare
                    elseif states.currentPetTable == "Epic" then petList = petRefsEpic
                    elseif states.currentPetTable == "Unique" then petList = petRefsUnique
                    end
                    handleItemSelection(states.currentPetLabel, petList, petDetails, "pet")
                end
                if states.currentAuraLabel then
                    local auraList = auraRefsBasic
                    if states.currentAuraTable == "Basic" then auraList = auraRefsBasic
                    elseif states.currentAuraTable == "Advanced" then auraList = auraRefsAdv
                    elseif states.currentAuraTable == "Rare" then auraList = auraRefsRare
                    elseif states.currentAuraTable == "Epic" then auraList = auraRefsEpic
                    elseif states.currentAuraTable == "Unique" then auraList = auraRefsUnique
                    end
                    handleAuraSelection(states.currentAuraLabel, auraList, auraDetails)
                end
                
                local uStr, ultF = "", tp:FindFirstChild("ultimatesFolder");
                if ultF then for _, u in ipairs(ultF:GetChildren()) do uStr = uStr .. u.Name .. ": " .. formatNum(u.Value) .. "\n" end end;
                ultList.Text = uStr == "" and "None" or uStr
                
                local gpStr, opF = "", tp:FindFirstChild("ownedGamepasses")
                if opF then for _, g in ipairs(opF:GetChildren()) do gpStr = gpStr .. g.Name .. "\n" end end
                gpList.Text = gpStr == "" and "None" or gpStr
                
            else resetStatsUI() end
        else for s, label in pairs(statsDisp) do label.Text = s .. ": None" end end
    end
end))

