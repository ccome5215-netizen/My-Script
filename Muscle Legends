            if targetHand then 
                if not rockCache[actualRockPart] then 
                    rockCache[actualRockPart] = {Size = actualRockPart.Size, CanCollide = actualRockPart.CanCollide, CFrame = actualRockPart.CFrame} 
                end
                local mySize = player:FindFirstChild("customSize") and player.customSize.Value or tonumber(Config.SizeValue) or 1
                local newSize = (mySize >= 2) and 2 or 1
                actualRockPart.Size = Vector3.new(newSize, newSize, newSize)
