local SetToggle = {}
local function createToggle(parent, text, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -10, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text .. " [OFF]"
    btn.TextColor3 = Color3.new(1, 1, 1)
    local state = false
    
    SetToggle[btn] = function(newState)
        state = newState
        btn.Text = text .. (state and " [ON]" or " [OFF]")
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(45, 45, 45)
    end

    btn.MouseButton1Click:Connect(function()
        local newState = not state
        if callback(newState) == false then newState = false end 
        SetToggle[btn](newState)
    end)
    return btn
end

local function createDropdown(parent, text, options, multi, callback, checkStateFunc)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -10, 0, 30)
    container.BackgroundTransparency = 1
    
    local headerText = Instance.new("TextLabel", container)
    headerText.Size = UDim2.new(1, 0, 0, 30)
    headerText.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    headerText.Text = text .. " v"
    headerText.TextColor3 = Color3.new(1, 1, 1)
    headerText.Active = true
    
    -- Hidden button overlay for click detection on the header
    local headerBtn = Instance.new("TextButton", container)
    headerBtn.Size = UDim2.new(1, 0, 0, 30)
    headerBtn.BackgroundTransparency = 1
    headerBtn.Text = ""
    headerBtn.ZIndex = 12
    
    local list = Instance.new("ScrollingFrame", container)
    list.Position = UDim2.fromOffset(0, 30)
    list.Visible = false
    list.ZIndex = 10
    list.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    list.ScrollBarThickness = isMobile and 6 or 4
    list.ScrollingEnabled = true
    list.ClipsDescendants = true
    list.ElasticBehavior = Enum.ElasticBehavior.WhenScrollable
    
    headerBtn.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
        local listHeight = math.min(#options * 25, 150)
        container.Size = list.Visible and UDim2.new(1, -10, 0, listHeight + 30) or UDim2.new(1, -10, 0, 30)
        list.Size = UDim2.new(1, 0, 0, listHeight)
        list.CanvasSize = UDim2.new(0, 0, 0, #options * 25)
    end)
    
    local function refresh(newOpts)
        if newOpts then
            options = newOpts
        end
        for _, v in ipairs(list:GetChildren()) do v:Destroy() end
        for i, opt in ipairs(options) do
            local o = Instance.new("TextButton", list)
            o.Size = UDim2.new(1, 0, 0, 25)
            o.Position = UDim2.fromOffset(0, (i-1)*25)
            o.Text = tostring(opt)
            o.TextColor3 = Color3.new(1, 1, 1)
            o.ZIndex = 11
            
            if multi and checkStateFunc then
                local isActive = checkStateFunc(opt)
                o.BackgroundColor3 = isActive and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
            else
                o.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            end

            o.MouseButton1Click:Connect(function()
                if not multi then
                    headerText.Text = tostring(opt) .. " v"
                    list.Visible = false
                    container.Size = UDim2.new(1, -10, 0, 30)
                    callback(opt)
                else
                    local newState = callback(opt)
                    o.BackgroundColor3 = newState and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
                end
            end)
