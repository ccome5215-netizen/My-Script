-- ==================== KILLER LOOP - OPTIMIZED ====================
local function startKillerLoop()
    if getgenv().ML_Expert_Loops.killerLoop then
        pcall(task.cancel, getgenv().ML_Expert_Loops.killerLoop)
    end
    
    getgenv().ML_Expert_Loops.killerLoop = task.spawn(function()
        while true do
            task.wait(0.1)
            
            local effectiveTargets = {}
            
            -- Build target list from enabled sources
            if killerState.killSelectedEnabled then
                for username in pairs(killerState.selectedPlayers) do
                    if not isWhitelisted(username) then
                        effectiveTargets[username] = true
                    end
                end
            end
            
            if killerState.killEveryoneEnabled then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= player and not isWhitelisted(plr.Name) then
                        effectiveTargets[plr.Name] = true
                    end
                end
            end
            
            if killerState.autoGoodKarmaEnabled or killerState.autoEvilKarmaEnabled then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr == player then continue end
                    local karma = plr:FindFirstChild("Karma")
                    if not karma then continue end
                    
                    local isGoodKarma = karma.Value > 0
                    local shouldKill = (killerState.autoGoodKarmaEnabled and isGoodKarma) or 
                                      (killerState.autoEvilKarmaEnabled and not isGoodKarma)
                    
                    if shouldKill and not isWhitelisted(plr.Name) then
                        effectiveTargets[plr.Name] = true
                    end
                end
            end
            
            -- Execute kills on targets
            for username in pairs(effectiveTargets) do
                local targetPlr = getPlayerFromUsername(username)
                if targetPlr and targetPlr.Character then
                    disableAttachmentsForPlayer(username)
                    -- Add your kill logic here
                end
            end
            
            -- Cleanup targets no longer in effective set
            for username in pairs(activeKillTargets) do
                if not effectiveTargets[username] then
                    enableAttachmentsForPlayer(username)
                    activeKillTargets[username] = nil
                end
            end
            
            -- Update active targets
            for username in pairs(effectiveTargets) do
                activeKillTargets[username] = true
            end
        end
    end)
    
    table.insert(getgenv().ML_Expert_Loops, getgenv().ML_Expert_Loops.killerLoop)
end

